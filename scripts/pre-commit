#!/bin/sh
# =============================================================
# Pre-commit hook para mindease-app
# Antes de cada commit:
#   1. Corrige lint automaticamente (dart fix + dart format)
#   2. Bloqueia se houver erros que não podem ser corrigidos
#   3. Verifica código não utilizado (imports, variáveis, funções)
#   4. Verifica arquivos .dart não utilizados em lib/
#   5. Bloqueia se cobertura de código for menor que 80%
# =============================================================

set -e

MIN_COVERAGE=80
FAILED=0

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo "${CYAN}═══════════════════════════════════════════${NC}"
echo "${CYAN}  Pre-commit checks - mindease-app${NC}"
echo "${CYAN}═══════════════════════════════════════════${NC}"
echo ""

# =============================================================
# Check 1: Auto-fix lint + flutter analyze
# =============================================================
echo "${CYAN}[1/3] Corrigindo lint automaticamente e analisando...${NC}"
echo ""

# Auto-fix: aplica correções automáticas de lint
echo "   Aplicando dart fix --apply..."
dart fix --apply 2>&1 || true

echo "   Aplicando dart format..."
dart format lib/ test/ 2>&1 || true

# Re-adiciona arquivos corrigidos ao staging
git add -u

# Agora analisa o código após as correções automáticas
ANALYZE_OUTPUT=$(flutter analyze 2>&1) || true

# Verifica imports, variáveis, funções e campos não utilizados
UNUSED_ISSUES=$(echo "$ANALYZE_OUTPUT" | grep -iE "unused_import|unused_element|unused_field|unused_local_variable|dead_code" || true)

if [ -n "$UNUSED_ISSUES" ]; then
    UNUSED_COUNT=$(echo "$UNUSED_ISSUES" | wc -l | tr -d ' ')
    echo "${RED}❌ Código não utilizado detectado ($UNUSED_COUNT ocorrência(s)) - não foi possível corrigir automaticamente:${NC}"
    echo ""
    echo "$UNUSED_ISSUES"
    echo ""
    FAILED=1
else
    echo "${GREEN}✅ Nenhum código não utilizado detectado pelo analyzer${NC}"
fi

# Verifica erros de análise
ERRORS=$(echo "$ANALYZE_OUTPUT" | grep -c "error •" || true)
if [ "$ERRORS" -gt 0 ]; then
    echo "${RED}❌ Flutter analyze encontrou $ERRORS erro(s) que não puderam ser corrigidos automaticamente:${NC}"
    echo ""
    echo "$ANALYZE_OUTPUT" | grep "error •"
    echo ""
    FAILED=1
else
    echo "${GREEN}✅ Nenhum erro de análise encontrado${NC}"
fi

echo ""

# =============================================================
# Check 2: Arquivos .dart não utilizados
# =============================================================
echo "${CYAN}[2/3] Verificando arquivos não utilizados...${NC}"
echo ""

UNUSED_FILES_OUTPUT=$(dart run scripts/check_unused_files.dart 2>&1) || UNUSED_FILES_EXIT=$?
echo "$UNUSED_FILES_OUTPUT"

if [ "${UNUSED_FILES_EXIT:-0}" -ne 0 ]; then
    FAILED=1
fi

echo ""

# =============================================================
# Check 3: Testes + Cobertura de código >= 80%
# =============================================================
echo "${CYAN}[3/3] Executando testes com cobertura...${NC}"
echo ""

flutter test --coverage 2>&1 || {
    echo ""
    echo "${RED}❌ Testes falharam! Commit bloqueado.${NC}"
    exit 1
}

echo ""

if [ ! -f coverage/lcov.info ]; then
    echo "${RED}❌ Arquivo de cobertura (coverage/lcov.info) não encontrado${NC}"
    exit 1
fi

# Calcula cobertura a partir do lcov.info
TOTAL_LINES=0
COVERED_LINES=0

while IFS= read -r line; do
    case "$line" in
        LF:*)
            val="${line#LF:}"
            TOTAL_LINES=$((TOTAL_LINES + val))
            ;;
        LH:*)
            val="${line#LH:}"
            COVERED_LINES=$((COVERED_LINES + val))
            ;;
    esac
done < coverage/lcov.info

if [ "$TOTAL_LINES" -eq 0 ]; then
    echo "${YELLOW}⚠️  Nenhuma linha encontrada no relatório de cobertura${NC}"
    COVERAGE=0
else
    COVERAGE=$((COVERED_LINES * 100 / TOTAL_LINES))
fi

echo "   Linhas cobertas: $COVERED_LINES / $TOTAL_LINES ($COVERAGE%)"
echo ""

if [ "$COVERAGE" -lt "$MIN_COVERAGE" ]; then
    echo "${RED}❌ Cobertura de código ($COVERAGE%) está abaixo do mínimo exigido ($MIN_COVERAGE%)${NC}"
    FAILED=1
else
    echo "${GREEN}✅ Cobertura de código ($COVERAGE%) atende o mínimo exigido ($MIN_COVERAGE%)${NC}"
fi

# =============================================================
# Resultado final
# =============================================================
echo ""
echo "${CYAN}═══════════════════════════════════════════${NC}"

if [ "$FAILED" -eq 1 ]; then
    echo "${RED}❌ COMMIT BLOQUEADO - Corrija os problemas acima.${NC}"
    echo "${CYAN}═══════════════════════════════════════════${NC}"
    echo ""
    exit 1
else
    echo "${GREEN}✅ Todas as verificações passaram!${NC}"
    echo "${CYAN}═══════════════════════════════════════════${NC}"
    echo ""
    exit 0
fi
